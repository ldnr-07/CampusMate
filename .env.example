# ============================================================
# CampusMate Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file — it's in .gitignore.
# ============================================================

# Supabase — get these from your Supabase project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# EmailJS — sign up at https://www.emailjs.com
# Then set the values in src/js/config.js
# EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
# EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
# EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Then set CLIENT_ID in src/js/config.js
# GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
