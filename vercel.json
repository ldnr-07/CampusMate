{
  "version": 2,
  "public": true,
  "github": {
    "enabled": false
  },
  "builds": [
    {
      "src": "src/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/src/landing page.html"
    },
    {
      "src": "/app",
      "dest": "/src/logSign.html"
    },
    {
      "src": "/auth",
      "dest": "/src/logSign.html"
    },
    {
      "src": "/(.*)",
      "dest": "/src/$1"
    }
  ]
}
